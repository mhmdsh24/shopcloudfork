# Make sure shell scripts always use LF so they are executable
# on Linux/macOS/Git Bash regardless of whether the repo was
# checked out on Windows.
*.sh             text eol=lf
*.py             text eol=lf
*.tf             text eol=lf
*.tfvars         text eol=lf
*.yaml           text eol=lf
*.yml            text eol=lf
*.conf           text eol=lf
Dockerfile       text eol=lf
Dockerfile.*     text eol=lf
.gitignore       text eol=lf
.gitattributes   text eol=lf
